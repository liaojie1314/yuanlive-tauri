{
  "name": "yuanlive-tauri",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "preinstall": "npx only-allow pnpm",
    "commit": "git add . && lint-staged && git-cz && conventional-changelog -p cz-config.js -i CHANGELOG.md -s -r 0",
    "changelog": "conventional-changelog -p cz-config.js -i CHANGELOG.md -s -r 0",
    "lint:staged": "lint-staged"
  },
  "lint-staged": {
    "*.{js,jsx,vue,ts,tsx}": [
      "oxlint --fix",
      "prettier --config .prettierrc --write",
      "eslint src"
    ]
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "naive-ui": "^2.43.2",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.23.3",
    "@tauri-apps/cli": "^2",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "@unocss/preset-uno": "^66.5.9",
    "@unocss/reset": "^66.5.9",
    "@unocss/transformer-directives": "^66.5.9",
    "@unocss/vite": "^66.5.9",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitejs/plugin-vue-jsx": "^5.1.2",
    "@vue/eslint-config-typescript": "^14.6.0",
    "commitizen": "^4.3.0",
    "conventional-changelog": "^5.1.0",
    "conventional-changelog-cli": "^4.1.0",
    "cz-conventional-changelog": "^3.3.0",
    "cz-customizable": "^7.0.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "^5.0.1",
    "eslint-plugin-vue": "^9.19.2",
    "lint-staged": "^15.2.0",
    "only-allow": "^1.2.1",
    "oxlint": "^0.0.20",
    "prettier": "^3.1.1",
    "sass": "^1.94.2",
    "sass-loader": "^16.0.6",
    "typescript": "~5.6.2",
    "unplugin-auto-import": "^20.2.0",
    "unplugin-vue-components": "^30.0.0",
    "vite": "^6.0.3",
    "vue-tsc": "^2.1.10"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-customizable"
    },
    "cz-customizable": {
      "config": "config/cz-config.cjs"
    }
  }
}
