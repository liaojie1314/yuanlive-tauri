  "scripts": {
    "======== 启动vue(tauri项目会连带执行不需要单独执行) ========": "",
    "dev": "vite",
    "======== 打包vue(tauri项目会连带执行不需要单独执行) ========": "",
    "build": "vue-tsc --noEmit && vite build",
    "======== 生成打包报告 ========": "",
    "report": "rimraf dist && vite build",
    "======== 清除缓存 ========": "",
    "clean:cache": "rimraf src-tauri/target && rimraf dist && rimraf pnpm-lock.yaml && rimraf node_modules && pnpm store prune && pnpm install",
    "======== 启动桌面应用程序 ========": "",
    "tauri:dev": "tauri dev",
    "======== 启动 ios 程序 ========": "",
    "tauri:ios:dev": "tauri ios dev",
    "======== 启动 android 程序 ========": "",
    "tauri:android:dev": "tauri android dev",
    "======== 交互式打包程序 ========": "",
    "tauri:build": "node scripts/interactive-build-inquirer.js",
    "======== 生成icon ========": "",
    "tauri:icon": "tauri icon public/logo.png",
    "======== 安装依赖前执行 ========": "",
    "preinstall": "pnpm dlx only-allow pnpm && node scripts/check-all.js",
    "======== 安装依赖后执行复制依赖文件 ========": "",
    "postinstall": "shx mkdir -p public/selfie_segmentation && shx cp -r node_modules/@mediapipe/selfie_segmentation/* public/selfie_segmentation/ && node scripts/setup-env.js",
    "======== 使用commit来进行代码提交 ========": "",
    "commit": "git add . && git-cz",
    "======== 只检查代码问题和格式(不修复) ========": "",
    "check": "biome check",
    "======== 修复代码问题和格式并且检查 ========": "",
    "check:write": "biome check --write --unsafe",
    "======== 格式化Vue文件模板 ========": "",
    "format:vue": "pnpm dlx prettier --write \"src/**/*.vue\"",
    "======== 完整格式化(JS+Vue) ========": "",
    "format:all": "pnpm check:write && pnpm format:vue",
    "======== Git提交前的代码检查 ========": "",
    "lint:staged": "lint-staged && vue-tsc --noEmit",
    "======== 安装husky ========": "",
    "prepare": "husky",
    "======== 发版 ========": "",
    "release": "release-it",
    "======== commit后再次添加修改到上一次的commit ========": "",
    "addition-commit": "git add . && git commit --amend --no-edit",
    "======== 单独提交 ========": "",
    "gitcz": "git-cz",
    "======== 代码统计 ========": "",
    "stats": "cloc --vcs git .",
    "======== 单元测试 ========": "",
    "test:unit": "vitest run",
    "======== 使用 vitest UI ========": "",
    "test:ui": "vitest --ui --coverage.enabled=true",
    "======== 测试覆盖率 ========": "",
    "test:coverage": "vitest run --coverage",
    "======== E2E 测试 (Playwright) ========": "",
    "test:e2e": "playwright test",
    "======== E2E 测试 (可视化模式) ========": "",
    "test:e2e:headed": "playwright test --headed",
    "======== E2E 测试 (UI模式) ========": "",
    "test:e2e:ui": "playwright test --ui",
    "======== E2E 测试报告 ========": "",
    "test:e2e:report": "playwright show-report"
  },
