{
  "name": "yuanlive-tauri",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "author": {
    "name": "yuanyuan",
    "email": "1517438366@qq.com",
    "url": "https://github.com/liaojie1314"
  },
  "repository": {
    "url": "https://github.com/liaojie1314/yuanlive-tauri.git"
  },
  "scripts": {
    "======== 启动vue(tauri项目会连带执行不需要单独执行) ========": "",
    "dev": "vite",
    "======== 打包vue(tauri项目会连带执行不需要单独执行) ========": "",
    "build": "vue-tsc --noEmit && vite build",
    "======== 启动桌面应用程序 ========": "",
    "tauri:dev": "tauri dev",
    "======== 打包桌面应用程序 ========": "",
    "tauri:build": "tauri build",
    "======== 安装依赖前执行 ========": "",
    "preinstall": "pnpm dlx only-allow pnpm && node scripts/check-all.js",
    "========= 使用commit来进行代码提交 =========": "",
    "commit": "git add . && git-cz",
    "========= 只检查代码问题和格式(不修复) =========": "",
    "check": "biome check",
    "========= 修复代码问题和格式并且检查 =========": "",
    "check:write": "biome check --write --unsafe",
    "========= 格式化Vue文件模板 =========": "",
    "format:vue": "npx prettier --write \"src/**/*.vue\"",
    "========= 完整格式化(JS+Vue) =========": "",
    "format:all": "pnpm check:write && pnpm format:vue",
    "========= Git提交前的代码检查 =========": "",
    "lint:staged": "lint-staged && vue-tsc --noEmit",
    "========= 安装husky =========": "",
    "prepare": "husky",
    "========= 单独提交 =========": "",
    "gitcz": "git-cz"
  },
  "dependencies": {
    "@fingerprintjs/fingerprintjs": "^5.0.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-fs": "~2.4.4",
    "@tauri-apps/plugin-http": "~2.5.4",
    "@tauri-apps/plugin-log": "~2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-os": "~2",
    "@tauri-apps/plugin-process": "~2.3.1",
    "@types/video.js": "^7.3.58",
    "dayjs": "^1.11.19",
    "es-toolkit": "^1.42.0",
    "highlight.js": "^11.11.1",
    "marked": "^17.0.1",
    "mitt": "^3.0.1",
    "naive-ui": "^2.43.2",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "pinia-shared-state": "^1.0.1",
    "video.js": "^8.23.4",
    "vue": "^3.5.13",
    "vue-i18n": "^11.2.2",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.8",
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@iconify-json/fluent": "^1.2.36",
    "@iconify-json/material-symbols": "^1.2.50",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/ph": "^1.2.2",
    "@iconify/vue": "^5.0.0",
    "@release-it/bumper": "^6.0.1",
    "@release-it/conventional-changelog": "8.0.2",
    "@tauri-apps/cli": "^2",
    "@types/node": "^24.10.1",
    "@types/postcss-pxtorem": "^6.1.0",
    "@unocss/preset-uno": "^66.5.9",
    "@unocss/preset-wind3": "^66.5.9",
    "@unocss/reset": "^66.5.9",
    "@unocss/transformer-directives": "^66.5.9",
    "@unocss/transformer-variant-group": "^66.5.9",
    "@unocss/vite": "^66.5.9",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vitejs/plugin-vue-jsx": "^5.1.2",
    "@vueuse/core": "^14.1.0",
    "chalk": "^5.6.2",
    "commitizen": "^4.3.1",
    "cz-git": "^1.12.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "only-allow": "^1.2.1",
    "postcss-pxtorem": "^6.1.0",
    "prettier": "^3.6.2",
    "release-it": "^17.11.0",
    "sass": "^1.94.2",
    "typescript": "^5.9.3",
    "unplugin-auto-import": "^20.2.0",
    "unplugin-icons": "^22.5.0",
    "unplugin-vue-components": "^30.0.0",
    "vite": "7.2.2",
    "vite-plugin-vue-setup-extend": "^0.4.0",
    "vue-tsc": "^2.1.10",
    "web-vitals": "^5.1.0"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0",
    "pnpm": ">=10.x"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  }
}
