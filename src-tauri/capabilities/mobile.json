{
  "$schema": "../gen/schemas/mobile-schema.json",
  "identifier": "mobile-capability",
  "description": "Capability for the main window",
  "platforms": ["iOS", "android"],
  "windows": ["*"],
  "permissions": [
    "core:default",
    "core:webview:allow-internal-toggle-devtools",
    "core:event:default",
    "log:default"
  ]
}
