{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "yuanlive-tauri",
  "version": "0.1.0",
  "identifier": "blog.yuanyuan.yuanlive",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "rimraf dist && pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null,
      "capabilities": ["default-capability"],
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "resources": ["configuration"],
    "externalBin": ["binaries/ffmpeg"],
    "active": true,
    "category": "Video",
    "copyright": "Copyright © 2026 YuanLive Team",
    "licenseFile": "./copyright/License.rtf",
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
    "windows": {},
    "macOS": {}
  },
  "plugins": {
    "updater": {
      "active": true,
      "windows": {
        "installMode": "passive"
      },
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhFQTZFMkFFMUMwQzNBOTkKUldTWk9nd2NydUttamd0U0ZSODd6Qm5NM3ZyWkhjdTJLZU5Fdkc1TG1nL2tldGxVUTM0QXJDcW8K",
      "endpoints": [
        "https://api.upgrade.toolsetlink.com/v1/tauri/upgrade?tauriKey=ZX0HwXKJXLTrwLYnExofXQ&versionName={{current_version}}&appointVersionName=&devModelKey=&devKey=&target={{target}}&arch={{arch}}"
      ]
    }
  }
}
